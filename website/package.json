    "postcss": "^8.5.16",
    "postcss-preset-mantine": "1.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.2.1",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.105.0"
