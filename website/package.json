    "@react-router/node": "^7.6.2",
    "@react-router/serve": "^7.6.2",
    "@tabler/icons-react": "^3.44.0",
    "dayjs": "^1.11.21",
    "drizzle-orm": "~0.45.2",
    "drizzle-zod": "^0.8.3",
    "isbot": "^5.1.17",
    "leaflet": "^1.9.4",
    "luxon": "^3.7.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router": "^7.6.2",
